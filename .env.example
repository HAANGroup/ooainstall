# ── Orbis Self-Hosted Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in the required values before starting.
# Generate secrets with: openssl rand -hex 32

# ── Required ──────────────────────────────────────────────────────────────────

# 64 hex characters — encrypts all secrets and credentials at rest
ENCRYPTION_KEY=

# PostgreSQL password for the orbis database user
DB_PASSWORD=

# JWT signing secret for user sessions
JWT_SECRET=

# ── Application ───────────────────────────────────────────────────────────────

NODE_ENV=production

# Your domain or server IP (used in emails and OAuth callbacks)
# Example: https://orbis.mycompany.com  or  http://192.168.1.100
APP_URL=http://localhost

# ── Default admin account ─────────────────────────────────────────────────────
# Created automatically on first boot if no users exist.
# The installer auto-generates ADMIN_PASSWORD — change it after first login.
ADMIN_EMAIL=admin@orbis.local
ADMIN_PASSWORD=

# ── Version ───────────────────────────────────────────────────────────────────
# Pin to a specific release tag (e.g. v1.2.0) or leave as 'latest'
ORBIS_VERSION=latest

# ── Connector registry — syncs available connectors on startup + every 24h ────
CONNECTOR_REGISTRY_URL=https://app.iamorbis.one/registry/connectors.json

# ── Email (for password reset, member invites, notifications) ─────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── OAuth Login (optional) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── AI Nodes (optional) ───────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Cloud mode — leave false for self-hosted ─────────────────────────────────
VITE_CLOUD_MODE=false
